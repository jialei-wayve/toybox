# Atlassian Cloud — create an API token at:
# https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_EMAIL=you@company.com
JIRA_API_TOKEN=

# Site URL (no trailing path), e.g. https://yourorg.atlassian.net
JIRA_SITE_BASE_URL=https://yourorg.atlassian.net

# API server port
PORT=3001

# rest (default) = Atlassian REST API. mcp = stub (implement transport yourself).
JIRA_BACKEND=rest

# Optional for advanced adapters (not required in REST mode)
JIRA_CLOUD_ID=
